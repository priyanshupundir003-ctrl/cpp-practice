class Solution {
public:
    char findKthBit(int n, int k) {
        string s ="0";

        for(int i = 2; i <= n; i++){  // s1 se s2 tak string banane ke liye
            string temp =s;
            reverse(temp.begin(),temp.end());
            for(int j = 0; j<temp.size(); j++){  //inverting ke liye 0-->1,1-->0
                if(temp[j] == '0') temp[j] = '1';
                else temp[j] = '0';
            }

            s = s + "1" +  temp;
        }
        return s[k-1];
    }
};
